# Public — your live frontend domain
NEXT_PUBLIC_SITE_URL=https://sakuraschoolsimulator.net

# Public — WordPress CMS base URL (admin, media links)
NEXT_PUBLIC_WORDPRESS_URL=https://cms.sakuraschoolsimulator.net

# WordPress GraphQL — required for CMS; must be set at BUILD time for image optimization
WORDPRESS_GRAPHQL_URL=https://cms.sakuraschoolsimulator.net/graphql

# Must match HEADLESS_REVALIDATION_SECRET in WordPress wp-config.php
# Generate: openssl rand -base64 32
REVALIDATION_SECRET=

# For draft preview: /api/preview?secret=...
# Generate: openssl rand -base64 32
WORDPRESS_PREVIEW_SECRET=

# ISR cache refresh interval (seconds)
WORDPRESS_REVALIDATE_SECONDS=3600

# Optional — WordPress Application Password (base64 user:pass) for draft preview
WORDPRESS_AUTH_TOKEN=

# Runtime (CloudPanel / PM2)
NODE_ENV=production
PORT=3000
